# ---- Server ----
LOGICA_HTTP_ADDR=:8080
LOGICA_ENV=dev
LOGICA_LOG_LEVEL=info

# ---- Database ----
LOGICA_DATABASE_URL=postgres://logica:logica@localhost:5432/logica?sslmode=disable

# ---- Auth ----
# Generate with: openssl rand -base64 64
LOGICA_JWT_SECRET=changeme-please-generate-with-openssl-rand-base64-64
LOGICA_ACCESS_TOKEN_TTL=15m
LOGICA_REFRESH_TOKEN_TTL=720h
LOGICA_REFRESH_COOKIE_DOMAIN=
LOGICA_REFRESH_COOKIE_SECURE=false

# ---- CORS (dev) ----
LOGICA_CORS_ORIGINS=http://localhost:5173

# ---- Object storage ----
# driver: local | s3
LOGICA_STORAGE_DRIVER=local
LOGICA_STORAGE_LOCAL_DIR=./data/uploads
LOGICA_S3_ENDPOINT=
LOGICA_S3_REGION=
LOGICA_S3_BUCKET=
LOGICA_S3_ACCESS_KEY=
LOGICA_S3_SECRET_KEY=

# ---- Print rendering ----
LOGICA_GOTENBERG_URL=http://localhost:3000

# ---- Defaults ----
LOGICA_DEFAULT_LOCALE=id-ID
LOGICA_DEFAULT_TIMEZONE=Asia/Jakarta
LOGICA_DEFAULT_CURRENCY=IDR

# ---- Bootstrap admin (used by `logica seed` if no user exists) ----
LOGICA_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
LOGICA_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!Now123
